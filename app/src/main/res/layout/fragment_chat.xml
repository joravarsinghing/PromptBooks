<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Centered intro state -->
    <LinearLayout
        android:id="@+id/chatIntro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:padding="24dp">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logo"
            android:contentDescription="App Logo"
            android:alpha="0.8"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/chatIntroText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your AI Bookkeeping Assistant"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try saying something like:"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <!-- Suggestion Chips (Styled TextViews) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="“Bought 50 notebooks for 250 dhs”"
            android:background="@drawable/bg_suggestion_chip"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textColor="@color/primary_blue"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="“Sold 12 notebooks for 120 dhs cash”"
            android:background="@drawable/bg_suggestion_chip"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textColor="@color/primary_blue"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="“Paid 80 dhs for taxi to meet a client”"
            android:background="@drawable/bg_suggestion_chip"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textColor="@color/primary_blue"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomBarContainer"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:animateLayoutChanges="true" />
    </ScrollView>

    <!-- Bottom input area -->
    <LinearLayout
        android:id="@+id/bottomBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="@color/surface_white"
        android:elevation="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_gray" />

        <LinearLayout
            android:id="@+id/chatBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/uploadIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_plus"
                app:tint="@color/primary_blue" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_input_bar"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp">

                <EditText
                    android:id="@+id/chatInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Type a message..."
                    android:maxLines="4"
                    android:minHeight="40dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/sendIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_send"
                android:visibility="gone"
                app:tint="@color/primary_blue" />

            <ImageView
                android:id="@+id/micIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/primary_blue" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
